<controls:MetroWindow x:Class="TriangulationToolApp.MainWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:viewModels="clr-namespace:TriangulationToolApp.ViewModels"
                      xmlns:ddes="http://schemas.devdept.com/winfx/2008/xaml/control"
                      xmlns:ddgr="http://schemas.devdept.com/winfx/2008/xaml/graphics"
                      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:views="clr-namespace:TriangulationToolApp.Views"
                      mc:Ignorable="d"
                      Title="Point Cloud Triangulation Tool" WindowState="Maximized"
                      TextElement.Foreground="{DynamicResource MaterialDesignBody}"
                      TextElement.FontWeight="Regular"
                      TextElement.FontSize="13"
                      TextOptions.TextFormattingMode="Ideal"
                      TextOptions.TextRenderingMode="Auto"
                      Background="{DynamicResource MaterialDesignPaper}"
                      FontFamily="{DynamicResource MaterialDesignFont}"
                      GlowBrush="{DynamicResource AccentColorBrush}"
                      BorderThickness="1" Icon="Resources/softcrits.ico"
                      d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel, IsDesignTimeCreatable=True}">
    <controls:MetroWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary
                    Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ProgressBar.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </controls:MetroWindow.Resources>
    <materialDesign:DialogHost x:Name="DialogHost" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" CloseOnClickAway="True" IsOpen="False"
                                   DialogClosing="OnDialogClosing">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <materialDesign:Card Padding="5" Margin="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Margin="5" Width="120" Content="Load" ToolTip="Load point cloud from file"
                        Command="{Binding LoadFileCommand}" Style="{DynamicResource MaterialDesignRaisedDarkButton}" />
                    <Button Grid.Column="1" Margin="5" Width="120" Content="Triangulate" ToolTip="Triangulate point cloud"
                        Command="{Binding TriangulateCommand}" Style="{DynamicResource MaterialDesignRaisedDarkButton}" />
                    <Button Grid.Column="2" Margin="5" Width="120" Content="Generate TDM File" ToolTip="Generate TDM File"
                        Command="{Binding GenerateSearchTreeCommand}" Style="{DynamicResource MaterialDesignRaisedDarkButton}" />
                    <Button Grid.Column="3" Margin="5" Width="120" Content="Export" ToolTip="Export mesh to DWG"
                        Command="{Binding ExportCommand}" Style="{DynamicResource MaterialDesignRaisedDarkButton}" />
                </Grid>
            </materialDesign:Card>

            <Grid Grid.Row="1">
                <ddes:ViewportLayout Name="ViewportLayout" SelectionColor="Red">
                    <ddes:ViewportLayout.BoundingBox>
                        <ddes:BoundingBox Lighting="False" />
                    </ddes:ViewportLayout.BoundingBox>
                    <ddes:ViewportLayout.Viewports>
                        <ddes:Viewport DisplayMode="{Binding DisplayMode}">
                            <ddes:Viewport.CoordinateSystemIcon>
                                <ddes:CoordinateSystemIcon Lighting="False" />
                            </ddes:Viewport.CoordinateSystemIcon>
                            <ddes:Viewport.ViewCubeIcon>
                                <ddes:ViewCubeIcon Lighting="False" />
                            </ddes:Viewport.ViewCubeIcon>
                            <ddes:Viewport.Background>
                                <ddgr:BackgroundSettings BottomColor="#FF434752" StyleMode="LinearGradient"
                                                     TopColor="#FF222329" />
                            </ddes:Viewport.Background>
                            <ddes:Viewport.Grids>
                                <ddes:Grid Step="10" Lighting="False" />
                            </ddes:Viewport.Grids>
                            <ddes:Viewport.ToolBar>
                                <ddes:ToolBar Position="HorizontalTopCenter">
                                    <ddes:ToolBar.Buttons>
                                        <ddes:HomeToolBarButton />
                                        <ddes:MagnifyingGlassToolBarButton />
                                        <ddes:ZoomWindowToolBarButton />
                                        <ddes:ZoomToolBarButton />
                                        <ddes:PanToolBarButton />
                                        <ddes:RotateToolBarButton />
                                        <ddes:ZoomFitToolBarButton />
                                    </ddes:ToolBar.Buttons>
                                </ddes:ToolBar>
                            </ddes:Viewport.ToolBar>
                        </ddes:Viewport>
                    </ddes:ViewportLayout.Viewports>
                </ddes:ViewportLayout>
                <Image IsHitTestVisible="False" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Width="200"
                   Source="Resources/Images/SoftcritsLogo.png" materialDesign:ShadowAssist.Darken="True" />

                <materialDesign:Card UniformCornerRadius="14" Padding="4"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12 12 12 12">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             Value="0"
                             IsIndeterminate="True" />
                </materialDesign:Card>
            </Grid>
            <materialDesign:Snackbar Grid.Row="1" MessageQueue="{materialDesign:MessageQueue}" x:Name="Snackbar" />
        </Grid>
    </materialDesign:DialogHost>
  
</controls:MetroWindow>