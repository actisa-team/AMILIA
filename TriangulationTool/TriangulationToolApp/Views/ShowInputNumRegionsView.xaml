<controls:MetroWindow x:Class="TriangulationToolApp.Views.ShowInputNumRegionsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
        ResizeMode="NoResize" EnableDWMDropShadow="True" WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight"
        Title = "{Binding Title}" MaxWidth="600" MinWidth="600"
        GlowBrush="{DynamicResource AccentColorBrush}"
        Background="{DynamicResource WindowBackgroundBrush}"
        IsCloseButtonEnabled="False"
        Height="200" Width="300"
        Loaded="ShowInputNumRegionsViewOnLoaded"
        >

    <controls:MetroWindow.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding AcceptCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </controls:MetroWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{Binding InformationMessage}" FontSize="18" TextWrapping="Wrap" TextAlignment="Center" Margin="5,20,5,5"/>
        <TextBox x:Name="TextBoxConfigurationName" Focusable="True" Grid.Row="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Margin="5"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Accept" Margin="5" FontSize="14" MinWidth="60" Command="{Binding AcceptCommand}" IsDefault="True"/>
            <Button Content="Cancel" Margin="5" FontSize="14" MinWidth="60" Command="{Binding CancelCommand}" IsCancel="True"/>
        </StackPanel>
    </Grid>
</controls:MetroWindow>
